---
const { dateCreated, instagramLink, linkedInLink, tiktokLink, githubLink, text, isFeatured, alias, role, color, tags1, tags2, tags3, link = '#', img } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<div class=`flex flex-col md:flex-row ${isFeatured == 'True' ? 'shadow-xl shadow-amber-100' : 'shadow-xl shadow-indigo-300'} border border-white/30 hover:shadow-[0_0_35px_rgba(165,180,252,0.45)] transition-all hover:-translate-y-1`>
    
    <div class="w-full md:w-52 shrink-0">
        <img
            src={`${baseUrl}/${img}`}
            class=`w-full h-56 md:h-full object-cover md:object-fill shadow-2xl ${color == 'amber' ? 'shadow-amber-100' : ''} ${color == 'white' ? 'shadow-white' : ''}`
        />
    </div>

    <div class=`bg-white/60 backdrop-blur-xl md:pl-5 [clip-path:polygon(0_0,100%_0,100%_100%,0_100%)] md:[clip-path:polygon(0_0,99%_0,100%_100%,0_100%)] w-full flex flex-col border-b-4 border-transparent hover:border-red-400 transition-all`>
        
        <div class="flex flex-col sm:flex-row justify-between px-4 md:pr-8 md:pl-0 pb-4 pt-4 items-start sm:items-center gap-4 sm:gap-0">
            <a href={`${baseUrl}/${link}`}>
                <div class="font-title text-3xl md:text-4xl bg-linear-to-b from-gray-700 to-indigo-500 bg-clip-text text-transparent">{alias}</div>
            </a>
            <div class="flex justify-start sm:justify-end w-full sm:w-auto">
                <div class=`rounded-full font-code flex justify-center items-center bg-indigo-500 text-amber-100 px-3 py-1 text-sm md:text-lg`>
                    {role}
                </div>
            </div>
        </div>

        <div class="px-4 pb-3 text-base md:text-lg">
            <p class="whitespace-pre-line">
                {text}
            </p>
        </div>

        <div class="px-4 pb-4 md:pb-3 flex flex-col md:flex-row items-start md:items-end justify-between h-full gap-4 md:gap-0">
            <div class="py-2 flex flex-wrap gap-2">
                {isFeatured == 'True' && (
                    <div class="truncate relative rounded-full border-2 border-indigo-400 px-3 py-1 shadow shadow-indigo-300 text-xs md:text-sm font-code flex justify-center items-center">Featured!</div>
                )}
                {tags1 && <div class="truncate relative rounded-full bg-indigo-200 px-3 py-1 text-xs md:text-sm font-code flex justify-center items-center">{tags1}</div>}
                {tags2 && <div class="truncate relative rounded-full bg-red-200 px-3 py-1 text-xs md:text-sm font-code flex justify-center items-center">{tags2}</div>}
                {tags3 && <div class="truncate relative rounded-full bg-purple-200 px-3 py-1 text-xs md:text-sm font-code flex justify-center items-center">{tags3}</div>}
            </div>

            <div class="flex gap-6 md:gap-10 py-2 pr-2 md:pr-5">
                {githubLink && (
                    <a href={`${githubLink}`}><img src={`${baseUrl}/images/github.svg`} alt="GitHub" class="w-5 md:w-6" /></a>
                )}
                {instagramLink && (
                    <a href={`${instagramLink}`}><img src={`${baseUrl}/images/instagram.svg`} alt="Instagram" class="w-5 md:w-6" /></a>
                )}
                {linkedInLink && (
                    <a href={`${linkedInLink}`}><img src={`${baseUrl}/images/linkedin.svg`} alt="LinkedIn" class="w-5 md:w-6" /></a>
                )}
                {tiktokLink && (
                    <a href={`${tiktokLink}`}><img src={`${baseUrl}/images/tiktok.svg`} alt="TikTok" class="w-5 md:w-6" /></a>
                )}
            </div>
        </div>
    </div>
</div>