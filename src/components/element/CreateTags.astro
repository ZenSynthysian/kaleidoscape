---
const { tags1, tags2, tags3 } = Astro.props;
---

<div class="px-4 py-2 flex flex-wrap gap-2 justify-center">
    {tags1 && <div class="truncate relative rounded-full bg-indigo-200 px-3 py-1 text-xs md:text-sm font-code flex justify-center items-center">{tags1}</div>}
    {tags2 && <div class="truncate relative rounded-full bg-red-200 px-3 py-1 text-xs md:text-sm font-code flex justify-center items-center">{tags2}</div>}
    {tags3 && <div class="truncate relative rounded-full bg-purple-200 px-3 py-1 text-xs md:text-sm font-code flex justify-center items-center">{tags3}</div>}
</div>